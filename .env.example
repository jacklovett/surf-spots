VITE_MAP_ACCESS_TOKEN=your-map-access-token

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5173/auth/google

FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
FACEBOOK_CALLBACK_URL=http://localhost:5173/auth/facebook

# Public app base URL (scheme + host + port, no path). Also used for SSR API Origin
# and the interim Remix /api/backend BFF → Spring Origin header; must match API CORS
# allowlist. TODO(auth-cookie-domain): after shared-domain cookies, BFF goes away;
# BASE_URL still needed for SSR Origin. See surf-spots-api/docs/staging-domain-setup.md.
# Browsers set Origin automatically; Remix/Node fetch does not.
BASE_URL=http://localhost:5173
VITE_API_URL=http://localhost:8080/api

# Session secret for signed session cookie (must match API SESSION_SECRET).
SESSION_SECRET=your-session-secret

# DB Credentials
DB_PASSWORD=your-db-password
DB_URL=your-db-url

# Scaleway configuration
SCW_ACCESS_KEY=your-scw-access-key
SCW_SECRET_KEY=your-scw-secret-key
SCW_DEFAULT_ORGANIZATION_ID=your-scw-default-organisation-id
SCW_DEFAULT_PROJECT_ID=your-scw-default-project-id

# Test account for e2e tests
TEST_USER_EMAIL=your-test@email.com
TEST_USER_PASSWORD=your-test-password
TEST_USER_NAME=Test User